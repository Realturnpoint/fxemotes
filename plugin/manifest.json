{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
	"Actions": [
		{
			"Icon": "imgs/icon",
			"Name": "Roleplay emote",
			"States": [
				{
					"Image": "imgs/action",
					"TitleAlignment": "middle",
					"FontSize": 11
				}
			],
			"SupportedInMultiActions": true,
			"UUID": "com.turnpoint.fxemotes.emote",
			"Tooltip": "Trigger an RP emote on your FiveM server with a single button press",
			"PropertyInspectorPath": "ui/EmoteActionPI.html",
			"Controllers": ["Keypad"]
		}
	],
	"Author": "Turnpoint",
	"Name": "Roleplay emote",
	"Description": "City-based emote picker for FiveM/RedM RP servers. Select your city, pick an emote, and trigger it from your Stream Deck.",
	"Icon": "imgs/plugin-icon",
	"URL": "https://github.com/Realturnpoint/fxemotes",
	"SupportURL": "https://github.com/Realturnpoint/fxemotes/issues",
	"Version": "1.0.0.1",
	"CodePath": "bin/plugin.js",
	"UUID": "com.turnpoint.fxemotes",
	"Category": "Roleplay emote",
	"CategoryIcon": "imgs/category-icon",
	"OS": [
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		},
		{
			"Platform": "mac",
			"MinimumVersion": "10.15"
		}
	],
	"Nodejs": {
		"Version": "20"
	},
	"SDKVersion": 3,
	"Software": {
		"MinimumVersion": "6.9"
	}
}
